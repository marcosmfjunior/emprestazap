# ─── Blockchain ───────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=<your_alchemy_api_key>
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/<your_alchemy_api_key>
ALCHEMY_WEBSOCKET_URL=wss://polygon-amoy.g.alchemy.com/v2/<your_alchemy_api_key>

# Filled automatically by: npm run deploy:amoy (from project root)
LOAN_FACTORY_ADDRESS=
BRZ_TOKEN_ADDRESS=
DEPLOY_BLOCK=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://p2puser:p2ppassword@localhost:5432/p2plending

# ─── Auth (Privy) ─────────────────────────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── On/Off-ramp (Transfero) ──────────────────────────────────────────────────
TRANSFERO_API_KEY=
TRANSFERO_API_URL=https://api.transfero.com/v1

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
