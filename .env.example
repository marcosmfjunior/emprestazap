# ─── Wallet ───────────────────────────────────────────────────────────────────
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=0x<your_private_key_here>

# ─── Alchemy ──────────────────────────────────────────────────────────────────
# https://dashboard.alchemy.com → Create App → Polygon Amoy
ALCHEMY_API_KEY=<your_alchemy_api_key>

# ─── Polygonscan ──────────────────────────────────────────────────────────────
# https://polygonscan.com/apis → Create API Key
POLYGONSCAN_API_KEY=<your_polygonscan_api_key>

# ─── Contract parameters ──────────────────────────────────────────────────────
# Amoy deploys MockBRZ automatically — only needed for mainnet
BRZ_TOKEN_ADDRESS=0x491a4eB4f1FC3BfF8E1d2FC856a6A46663aD556f
FEE_COLLECTOR_ADDRESS=<your_wallet_address>
FEE_BPS=200

# Gas Reporter
REPORT_GAS=false
